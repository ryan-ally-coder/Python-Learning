# function add setting
def add_setting(setting, setting_pair):
    # create a key and value and attach to setting_pair
    key, value = setting_pair
    key = key.lower()
    # check if key is in the setting (parameter 1)
    if key in setting:
        return f"Setting '{key}' already exists! Cannot add a new setting with this name."
    value = value.lower()
    # append key with value into the dictionary
    setting[key] = value
    return f"Setting '{key}' added with value '{value}' successfully!"
    # function
def update_setting(setting, new_setting_pair):
    # same as top one
    new_key, new_value = new_setting_pair
    new_key = new_key.lower()
    if new_key not in setting:
        return f"Setting '{new_key}' does not exist! Cannot update a non-existing setting."

    new_value = new_value.lower()
    # apply into dictionary
    setting[new_key] = new_value
    return f"Setting '{new_key}' updated to '{new_value}' successfully!"
    # function, different from previous two because the key has to be deleted directly from the setting parameter
def delete_setting(setting, del_key):
    del_key = del_key.lower()
    # check for the key trying to be deleted
    if del_key not in setting:
        return 'Setting not found!'
    # delete setting if found
    del setting[del_key]
    return f"Setting '{del_key}' deleted successfully!"
    # view setting function, only need setting parameter
def view_settings(setting):
    # if there are no settings
    if not setting:
        return 'No settings available.'
    # create header
    lines = ["Current User Settings:"]
    # for every key and value in setting
    for key, value in setting.items():
        # append to lines and capitalize the key
        lines.append(f"{key.capitalize()}: {value}")

    return "\n".join(lines) + "\n"
